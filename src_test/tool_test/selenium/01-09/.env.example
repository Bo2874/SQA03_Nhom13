# ==============================================================
# tool_test environment — copy to .env and adjust if needed
# ==============================================================

# --- URLs of the system under test (must be running locally) ---
BASE_URL_FE=http://localhost:3001
BASE_URL_BE=http://localhost:3000
API_PREFIX=/api/v1

# --- MySQL (matches docker-compose in infra/) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=elearning

# --- Redis (where backend stores OTP) ---
REDIS_HOST=localhost
REDIS_PORT=6379
OTP_PREFIX=otp

# --- Selenium ---
# BROWSER: edge | chrome | firefox  (Edge is pre-installed on Win 11)
BROWSER=edge
HEADLESS=false
IMPLICIT_WAIT=5
EXPLICIT_WAIT=10
