        <hashTree>

          <JSR223PreProcessor guiclass="TestBeanGui" testclass="JSR223PreProcessor" testname="Gen Email" enabled="true">
            <stringProp name="script">vars.put("std_email", "std_" + System.currentTimeMillis() + "@example.com");</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <SystemSampler guiclass="SystemSamplerGui" testclass="SystemSampler" testname="Seed OTP" enabled="true">
            <stringProp name="SystemSampler.command">cmd</stringProp>
            <elementProp name="SystemSampler.arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="Argument"><stringProp name="Argument.value">/c</stringProp></elementProp>
                <elementProp name="" elementType="Argument"><stringProp name="Argument.value">docker exec elearning-redis redis-cli SETEX otp:${std_email} 600 999999</stringProp></elementProp>
              </collectionProp>
            </elementProp>
          </SystemSampler>
          <hashTree/>

